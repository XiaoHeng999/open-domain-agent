# ──────────────────────────────────────────────
# Open Agent — Environment Variables Reference
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# These variables override config.yaml settings.
#
# Priority: CLI args > env vars > .env > config.yaml > defaults
# ──────────────────────────────────────────────

# ── Model ─────────────────────────────────────
# LLM provider: openai | anthropic | deepseek | local
OPEN_AGENT_MODEL_PROVIDER=openai

# Model name (provider-specific)
OPEN_AGENT_MODEL_NAME=gpt-4o

# API key (REQUIRED for cloud providers)
OPEN_AGENT_MODEL_API_KEY=sk-your-api-key-here

# Custom API base URL (optional, for proxies or compatible endpoints)
# OPEN_AGENT_MODEL_BASE_URL=https://api.openai.com/v1

# ── Safety ────────────────────────────────────
# strict | permissive | off
# OPEN_AGENT_SAFETY_LEVEL=strict

# ── Workspace ─────────────────────────────────
# OPEN_AGENT_WORKSPACE=.

# ── Sandbox ───────────────────────────────────
# daytona | docker | subprocess
# OPEN_AGENT_SANDBOX_BACKEND=subprocess
